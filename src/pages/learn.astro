---
import { getCollection } from "astro:content";
import BaseLayout from "../layouts/BaseLayout.astro";
import LessonCard from "../components/LessonCard.astro";

const dayOrder = [
  "monday",
  "tuesday",
  "wednesday",
  "thursday",
  "friday",
  "saturday",
  "sunday",
] as const;

const lessons = (await getCollection("lessons")).sort((a, b) => {
  const dayDiff = dayOrder.indexOf(a.data.day) - dayOrder.indexOf(b.data.day);
  if (dayDiff !== 0) return dayDiff;
  return a.data.time.localeCompare(b.data.time);
});

const styles = ["balboa", "lindy", "shag"] as const;
---
<BaseLayout title="Find lessons — bayareaswing">
  <section class="mb-10 max-w-3xl">
    <h1 class="text-4xl font-bold">Find a lesson</h1>
    <p class="mt-4 text-charcoal/85">
      Recurring weekly classes for newcomers and experienced dancers
      across San Francisco and the East Bay. Drop in — you don't need a
      partner.
    </p>
  </section>

  <section class="mb-8 flex flex-wrap items-center gap-3" data-filters>
    <span class="font-display text-sm uppercase tracking-widest text-brass-dark">
      Filter:
    </span>
    <button
      type="button"
      data-filter-style="all"
      class="border border-burgundy/30 bg-burgundy px-3 py-1 text-sm text-cream"
    >
      All styles
    </button>
    {styles.map((style) => (
      <button
        type="button"
        data-filter-style={style}
        class="border border-burgundy/30 bg-cream-dark/40 px-3 py-1 text-sm text-charcoal hover:bg-cream-dark"
      >
        {{ balboa: "Balboa", lindy: "Lindy Hop", shag: "Shag" }[style]}
      </button>
    ))}
  </section>

  <section class="grid gap-6 md:grid-cols-2" data-lessons>
    {lessons.map((lesson) => (
      <div data-style={lesson.data.style}>
        <LessonCard {...lesson.data} />
      </div>
    ))}
  </section>

  {lessons.length === 0 && (
    <p class="text-charcoal/70">
      No lessons listed yet. <a href="/contribute">Add the first one →</a>
    </p>
  )}
</BaseLayout>

<script>
  const buttons = document.querySelectorAll<HTMLButtonElement>("[data-filter-style]");
  const cards = document.querySelectorAll<HTMLElement>("[data-lessons] > [data-style]");

  const setActive = (active: HTMLButtonElement) => {
    for (const btn of buttons) {
      const isActive = btn === active;
      btn.classList.toggle("bg-burgundy", isActive);
      btn.classList.toggle("text-cream", isActive);
      btn.classList.toggle("bg-cream-dark/40", !isActive);
      btn.classList.toggle("text-charcoal", !isActive);
    }
  };

  for (const btn of buttons) {
    btn.addEventListener("click", () => {
      const filter = btn.dataset.filterStyle;
      setActive(btn);
      for (const card of cards) {
        card.style.display =
          filter === "all" || card.dataset.style === filter ? "" : "none";
      }
    });
  }
</script>
