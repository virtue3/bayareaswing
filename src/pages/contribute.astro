---
import BaseLayout from "../layouts/BaseLayout.astro";

const newFileUrl =
  "https://github.com/virtue3/bayareaswing/new/main/src/content/lessons";
const repoUrl = "https://github.com/virtue3/bayareaswing";
---
<BaseLayout title="Add a lesson — bayareaswing">
  <section class="max-w-3xl">
    <h1 class="text-4xl font-bold">Add or update a lesson</h1>
    <p class="mt-4 text-charcoal/85">
      This site is community-maintained. Lessons live as small YAML files
      in the GitHub repo — anyone can propose a change through GitHub's
      web editor in a few minutes. No git command line required.
    </p>

    <h2 class="mt-12 text-2xl font-bold">Quick path: add a new lesson</h2>
    <ol class="mt-4 list-decimal space-y-3 pl-6 text-charcoal/85">
      <li>
        <a href={newFileUrl} rel="noopener">
          Click here to create a new lesson file
        </a>
        . GitHub will prompt you to sign in or fork the repo if needed.
      </li>
      <li>
        Name the file something descriptive, like
        <code class="bg-cream-dark/60 px-1 py-0.5 text-sm">
          monday-balboa-verdi-club.yaml
        </code>
        — lowercase, words joined with dashes, ends in
        <code class="bg-cream-dark/60 px-1 py-0.5 text-sm">.yaml</code>.
      </li>
      <li>
        Paste the template below and fill it in.
      </li>
      <li>
        Scroll down, click <strong>Propose changes</strong>, then
        <strong>Create pull request</strong>. A maintainer will review it
        and merge.
      </li>
    </ol>

    <h2 class="mt-12 text-2xl font-bold">Template</h2>
    <pre class="mt-4 overflow-x-auto border border-burgundy/20 bg-cream-dark/60 p-4 text-sm leading-relaxed"><code>{`name: "Monday Night Balboa"
style: balboa            # balboa | lindy | shag
day: monday              # monday … sunday (lowercase)
time: "19:30-21:00"      # 24-hour, range
venue: "Verdi Club"
address: "2424 Mariposa St, San Francisco, CA"
neighborhood: "Mission"  # optional
level: all-levels        # beginner | intermediate | advanced | all-levels
instructor: "Jane Doe"   # optional
cost: "$15 drop-in"      # optional
contact: "https://example.com"  # optional
notes: "First lesson free for newcomers."  # optional
`}</code></pre>

    <h2 class="mt-12 text-2xl font-bold">Updating or removing a lesson</h2>
    <p class="mt-4 text-charcoal/85">
      Browse
      <a href={`${repoUrl}/tree/main/src/content/lessons`} rel="noopener">
        the lessons folder
      </a>
      , open the file you want to change, and click the pencil icon to
      edit. Same flow — propose changes, open a PR.
    </p>

    <h2 class="mt-12 text-2xl font-bold">What we'll review</h2>
    <ul class="mt-4 list-disc space-y-2 pl-6 text-charcoal/85">
      <li>The lesson is real, currently happening, and in the SF Bay Area.</li>
      <li>The style is balboa, lindy hop, or collegiate shag.</li>
      <li>Address and time look right; contact link works.</li>
    </ul>

    <p class="mt-12 text-charcoal/70">
      Stuck? Open an
      <a href={`${repoUrl}/issues/new`} rel="noopener">issue on GitHub</a>
      describing the lesson and we'll add it for you.
    </p>
  </section>
</BaseLayout>
