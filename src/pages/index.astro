---
import { getCollection } from "astro:content";
import BaseLayout from "../layouts/BaseLayout.astro";

const dances = [
  {
    name: "Lindy Hop",
    origin: "Harlem, 1920s–30s",
    blurb: "The mother of all swing dances. Joyful, improvisational, and rooted in African American vernacular movement.",
    href: "/the-dances#lindy",
  },
  {
    name: "Balboa",
    origin: "Southern California, 1920s",
    blurb: "Born on crowded California ballroom floors. Fast, close, and intricate - a dance that makes higher tempos feel natural.",
    href: "/the-dances#balboa",
  },
  {
    name: "Collegiate Shag",
    origin: "Southeast US, 1930s",
    blurb: "Fast, bouncy, and irresistibly fun. A distinctive rhythm and pure joy at high tempos.",
    href: "/the-dances#shag",
  },
];

const dayOrder = [
  "monday",
  "tuesday",
  "wednesday",
  "thursday",
  "friday",
  "saturday",
  "sunday",
] as const;

const dayLabel = (day: (typeof dayOrder)[number]) =>
  day.charAt(0).toUpperCase() + day.slice(1);

const weeklyNights = (await getCollection("lessons"))
  .map((entry) => entry.data)
  .sort((a, b) => dayOrder.indexOf(a.day) - dayOrder.indexOf(b.day));

const faqs = [
  {
    q: "Do I need a partner to come to class?",
    a: "No. All Bay Area venues rotate partners in class, so you'll dance with multiple people throughout the evening. Coming solo is completely normal — and encouraged.",
  },
  {
    q: "What should I wear?",
    a: "Comfortable clothes you can move in. Leather-soled or suede-soled shoes are ideal — they let you pivot safely. Sneakers work fine for beginners. Avoid rubber soles, which can grip the floor and strain your knees.",
  },
  {
    q: "Which dance should I start with?",
    a: "Lindy Hop. It's the most widely taught, has the largest community, and opens the door to all other swing styles. Most week nights include a beginner Lindy Hop lesson before the social dancing.",
  },
  {
    q: "How much does it cost?",
    a: "Weekly social dances are $10–20 at the door and usually include a beginner lesson. Monthly class series are separate — typically $50–80 per month.",
  },
  {
    q: "What's the difference between Lindy Hop and East Coast Swing?",
    a: "East Coast Swing is a simplified, standardized version developed in the 1940s for ballroom studios. Lindy Hop is the original: more improvisational, musically nuanced, and rooted in African American vernacular jazz tradition.",
  },
];
---
<BaseLayout title="Bay Area Swing Dancing — Lindy Hop, Balboa & Shag">
  <section class="min-h-screen flex flex-col items-center justify-center text-center px-6 pt-24 pb-16">
    <p class="text-red text-xs tracking-widest uppercase mb-4">San Francisco Bay Area</p>
    <h1 class="text-cream text-6xl md:text-8xl lg:text-9xl font-bold tracking-tight leading-none mb-6">
      Swing<br/>Dancing
    </h1>
    <p class="text-cream-dim text-base md:text-lg max-w-md leading-relaxed mb-8">
      Lindy Hop. Balboa. Shag. The original partner dances, alive and swinging every week across the Bay.
    </p>
    <div class="flex flex-wrap gap-3 justify-center">
      <a href="/the-dances" class="bg-red text-cream text-xs tracking-widest uppercase px-6 py-3 no-underline hover:bg-transparent hover:text-red border border-red transition-colors duration-200">Discover the Dances</a>
      <a href="/find-classes" class="border border-neutral-600 text-cream text-xs tracking-widest uppercase px-6 py-3 no-underline hover:border-cream transition-colors duration-200">Find a Class</a>
    </div>
  </section>

  <div class="border-t border-neutral-800 mx-6 md:mx-12"></div>

  <section class="px-6 md:px-12 py-16 max-w-5xl mx-auto">
    <p class="text-neutral-500 text-xs tracking-widest uppercase mb-10">The Dances</p>
    <div class="grid md:grid-cols-3 gap-px bg-neutral-800">
      {dances.map((d) => (
        <a href={d.href} class="bg-neutral-950 hover:bg-neutral-900 p-8 no-underline text-inherit block transition-colors group">
          <p class="text-red text-xs tracking-widest uppercase mb-3">{d.name}</p>
          <p class="text-neutral-500 text-xs mb-4">{d.origin}</p>
          <p class="text-cream-dim text-sm leading-relaxed">{d.blurb}</p>
          <p class="text-neutral-500 text-xs mt-4 group-hover:text-cream transition-colors">Learn more →</p>
        </a>
      ))}
    </div>
  </section>

  <div class="border-t border-neutral-800 mx-6 md:mx-12"></div>

  <section class="px-6 md:px-12 py-16 max-w-5xl mx-auto">
    <p class="text-neutral-500 text-xs tracking-widest uppercase mb-10">Weekly Dances with Lessons</p>
    <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-px bg-neutral-800">
      {weeklyNights.map((n) => (
        <a href="/find-classes" class="bg-neutral-950 hover:bg-neutral-900 p-6 no-underline block transition-colors">
          <p class="text-red text-xs tracking-widest uppercase mb-2">{dayLabel(n.day)}</p>
          <p class="text-cream text-sm font-medium mb-1">{n.name}</p>
          <p class="text-neutral-500 text-xs">{n.location}</p>
        </a>
      ))}
    </div>
    <div class="mt-6">
      <a href="/find-classes" class="text-xs tracking-widest uppercase text-neutral-400 hover:text-cream no-underline transition-colors">View full schedule →</a>
    </div>
  </section>

  <div class="border-t border-neutral-800 mx-6 md:mx-12"></div>

  <section id="about" class="px-6 md:px-12 py-16 max-w-5xl mx-auto">
    <div class="grid md:grid-cols-2 gap-12 items-start">
      <div>
        <h2 class="text-cream text-3xl md:text-4xl font-bold leading-tight mb-6">Dances born in jazz clubs, alive in the Bay</h2>
      </div>
      <div>
        <p class="text-cream-dim text-sm leading-relaxed mb-4">Vintage swing dances trace their roots to the 1920s–40s ballrooms of Harlem, the beach halls of Southern California, and the college towns of the American South. They were built for live jazz.</p>
        <p class="text-cream-dim text-sm leading-relaxed mb-4">Today, a tight-knit Bay Area community keeps these dances alive every week at venues from the Mission to North Beach to Oakland.</p>
        <p class="text-cream-dim text-sm leading-relaxed mb-6">No partner needed. No experience required.</p>
        <div class="flex flex-wrap gap-3">
          <a href="/the-dances" class="border border-neutral-600 text-cream text-xs tracking-widest uppercase px-5 py-2.5 no-underline hover:border-cream transition-colors">Explore the Dances</a>
          <a href="/find-classes" class="bg-red text-cream text-xs tracking-widest uppercase px-5 py-2.5 no-underline hover:bg-transparent hover:text-red border border-red transition-colors">Find a Class</a>
        </div>
      </div>
    </div>
  </section>

  <div class="border-t border-neutral-800 mx-6 md:mx-12"></div>

  <section id="faq" class="px-6 md:px-12 py-16 max-w-5xl mx-auto">
    <p class="text-neutral-500 text-xs tracking-widest uppercase mb-10">FAQ</p>
    <div class="max-w-2xl divide-y divide-neutral-800">
      {faqs.map((item) => (
        <details class="py-5 group">
          <summary class="text-cream text-sm font-medium cursor-pointer flex justify-between items-center list-none">
            {item.q}
            <span class="text-red text-lg leading-none group-open:rotate-45 transition-transform duration-200 inline-block">+</span>
          </summary>
          <p class="text-cream-dim text-sm leading-relaxed mt-3">{item.a}</p>
        </details>
      ))}
    </div>
  </section>
</BaseLayout>
